# Copy this file to backend/.env and fill in the required values.
#
#   cp backend/.env.example backend/.env
#
# Only the two fields below are mandatory. All other settings have defaults
# defined in backend/core/config.py — add them here only if you need to override.

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-hex-string

# DeepSeek API key. Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# --- Commonly overridden ---

# Redis address (change if Redis is remote or on a different port)
# REDIS_URL=redis://localhost:6379/0

# HuggingFace mirror for model downloads in China
# HF_ENDPOINT=https://hf-mirror.com

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
