# Research Navigator backend environment example.
# Copy this file to backend/.env and replace placeholder values before running the backend.

# Required: JWT signing key. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Required for LLM-powered features.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# Redis is used by Celery, API caching, login rate limiting, and task status features.
REDIS_URL=redis://localhost:6379/0

# SQLite database location.
# Defaults to backend/data/research_navigator.db.
# If overriding DATABASE_FILE, also set DATABASE_URL to the same database.
# DATABASE_FILE=C:/absolute/path/to/research_navigator.db
# DATABASE_URL=sqlite:///C:/absolute/path/to/research_navigator.db

# Runtime directories.
# Defaults are under backend/data/.
# UPLOAD_DIR=C:/absolute/path/to/uploads
# CHROMA_PERSIST_DIR=C:/absolute/path/to/chroma_db

# ChromaDB collection names.
CHUNKS_COLLECTION_NAME=document_chunks
SUMMARIES_COLLECTION_NAME=document_summaries
CHAPTER_SUMMARIES_COLLECTION_NAME=document_chapter_summaries

# Embedding and reranking models.
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
CROSS_ENCODER_MODEL_NAME=BAAI/bge-reranker-large

# DeepSeek-compatible OpenAI SDK settings.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REASONER_MODEL_NAME=deepseek-reasoner
DEEPSEEK_CHAT_MODEL_NAME=deepseek-chat

# RAG retrieval settings.
RAG_QUERY_TOP_K=10

# Document processor settings.
PROCESSOR_DOI_PRIMARY_SCAN_LIMIT=20
PROCESSOR_DOI_EXTENDED_SCAN_LIMIT=120
PROCESSOR_CROSSREF_TIMEOUT=10
PROCESSOR_LLM_METADATA_TRUNCATION=4000
PROCESSOR_LLM_SUMMARY_TRUNCATION=15000
PROCESSOR_CHUNK_SIZE=3000
PROCESSOR_CHUNK_OVERLAP=300
PROCESSOR_WIDE_TABLE_THRESHOLD=8

# Authentication and security.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
LOGIN_RATE_LIMIT_PER_MINUTE=10

# Observability.
LOG_LEVEL=INFO
SENTRY_DSN=
